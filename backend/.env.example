# База данных
#
# PostgreSQL (локально через `make db-up` из корня репозитория — см. backend/README.md):
# DATABASE_URL=postgresql+asyncpg://pereobuyka:pereobuyka@127.0.0.1:5432/pereobuyka
#
# SQLite — без Alembic/seed; удобно для быстрых прогонов API без Docker:
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Секрет для авторизации Telegram-бота (временная мера до реализации JWT)
BOT_SECRET=

# Админ API (Bearer для маршрутов /api/v1/admin/*). Пусто — ответ 403.
ADMIN_API_TOKEN=

# UUID пользователя-админа в БД (должен совпадать со seed — см. docs/tech/database-migrations.md)
ADMIN_ACTOR_USER_ID=00000000-0000-0000-0000-0000000000aa

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# OpenRouter — LLM (чат). STT — только переменные SPEECH_TO_TEXT_* ниже; см. ADR-005
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# NL→SQL админ-аналитика (ADR-006); опционально — дефолты в Settings
# ADMIN_NL_SQL_MAX_ROWS=200
# ADMIN_NL_SQL_STATEMENT_TIMEOUT_MS=15000

# Speech-to-text (ADR-005): `SPEECH_TO_TEXT_API_KEY`, `SPEECH_TO_TEXT_BASE_URL`, `SPEECH_TO_TEXT_MODEL` — для openrouter и openai_multipart
SPEECH_TO_TEXT_PROVIDER=openrouter
SPEECH_TO_TEXT_API_KEY=
# Как правило совпадает с OPENROUTER_BASE_URL; при openai_multipart — https://api.openai.com/v1
SPEECH_TO_TEXT_BASE_URL=https://openrouter.ai/api/v1
SPEECH_TO_TEXT_MODEL=openai/whisper-large-v3-turbo

# Параметры консультации (этап 3)
CONSULTATION_LLM_TIMEOUT_SECONDS=45
CONSULTATION_MAX_TOOL_ROUNDS=6
# Необязательно: переопределить системный промпт целиком (иначе — дефолт в коде)
CONSULTATION_SYSTEM_PROMPT=
