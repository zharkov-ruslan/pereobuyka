# База данных
# Локальная разработка (SQLite — создаётся автоматически, миграции не нужны):
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Секрет для авторизации Telegram-бота (временная мера до реализации JWT)
BOT_SECRET=
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pereobuyka

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# LLM (OpenRouter) — необходим только для модуля консультации (этап 3 плана)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
