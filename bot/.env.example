TELEGRAM_BOT_TOKEN=

LOG_LEVEL=INFO

# Backend API (лучше 127.0.0.1: см. README — localhost на Windows часто бьёт в IPv6)
BACKEND_BASE_URL=http://127.0.0.1:8000
# Секрет для авторизации бота в backend (должен совпадать с BOT_SECRET в backend/.env)
BOT_SECRET=

# LLM (OpenRouter) настраивается на стороне backend (`backend/.env`, см. backend/README.md).
# Бот ходит в backend endpoint `/api/v1/consultation/messages` (команда `/ask`):
# таймаут **чтения** одного HTTP-запроса (на бэке до нескольких раундов LLM+tools; 60 с часто мало)
# Часовой пояс для отображения дат в «Активные записи», /visits, /bonus (IANA; Telegram не передаёт TZ пользователя)
DISPLAY_TIMEZONE=Europe/Moscow
